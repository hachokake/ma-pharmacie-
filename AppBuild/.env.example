# Configuration de l'application Hotel App

# URL du serveur Django (à modifier selon votre configuration)
DJANGO_SERVER_URL=http://localhost:8000

# Pour réseau local, utilisez votre IP locale
# Exemple : DJANGO_SERVER_URL=http://192.168.1.100:8000

# Pour IP fixe ou serveur en ligne
# Exemple : DJANGO_SERVER_URL=https://monsite.com

# Nom de l'application
APP_NAME=Hotel App
APP_SHORT_NAME=Hotel

# Couleurs (format hexadécimal)
THEME_COLOR=#0d6efd
BACKGROUND_COLOR=#ffffff
ICON_BG_COLOR=#0f766e

# Version de l'application
APP_VERSION=1.0.0

# Configuration Android
ANDROID_APP_ID=com.hotelapp.pharmacy
ANDROID_MIN_SDK=21

# Configuration Electron
ELECTRON_APP_ID=com.hotelapp.pharmacy
